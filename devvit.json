{
  "$schema": "https://developers.reddit.com/schema/config-file.v1.json",
  "name": "daily-descent",
  "version": "0.1.0",
  "post": {
    "client": {
      "dir": "dist/client",
      "entry": "dist/client/index.html"
    }
  },
  "server": {
    "entry": "src/server/index.ts"
  },
  "permissions": {
    "reddit": {
      "asUser": [
        "SUBMIT_COMMENT"
      ]
    },
    "http": {
      "enable": true,
      "domains": [
        "generativelanguage.googleapis.com"
      ]
    }
  }
}
