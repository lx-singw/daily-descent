{
  "$schema": "https://developers.reddit.com/schema/config-file.v1.json",
  "name": "daily-descent",
  "post": {
    "dir": "dist/client",
    "entrypoints": {
      "default": {
        "entry": "index.html",
        "height": "tall"
      }
    }
  },
  "server": {
    "entry": "src/server/index.ts"
  },
  "permissions": {
    "reddit": {
      "asUser": [
        "SUBMIT_COMMENT"
      ]
    },
    "http": {
      "enable": true,
      "domains": [
        "generativelanguage.googleapis.com"
      ]
    }
  }
}
