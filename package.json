{
  "name": "daily-descent",
  "version": "0.1.0",
  "description": "The Daily Descent - A Reddit-native daily rogue-lite dungeon crawler",
  "main": "src/server/index.ts",
  "type": "module",
  "scripts": {
    "dev": "vite --config vite.config.ts",
    "dev:devvit": "devvit playtest",
    "build": "vite build --config vite.config.ts && tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@devvit/public-api": "^0.13.7",
    "@devvit/web": "^0.13.7",
    "express": "^5.2.1",
    "phaser": "^3.80.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "typescript": "^5.3.3",
    "vite": "^8.1.4",
    "vitest": "^1.3.1"
  }
}
